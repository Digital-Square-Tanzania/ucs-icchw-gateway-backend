doctype html
html
  head
    - const isSw = lang === 'sw';
    title #{isSw ? 'WAJA/UCS - Usimamizi wa Email za Uanzishaji' : 'WAJA/UCS - Admin Login'}
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href=`${ssrUrlPrefix}/css/styles.css`)
    style.
      html, body {
        height: auto;
        min-height: 100vh;
        overflow-y: auto;
      }
      body {
        min-height: 100vh;
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: radial-gradient(circle at top left, #dbeafe, #eff6ff 45%, #f9fafb 100%);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        color: #111827;
      }
      .page-shell {
        width: 100%;
        max-width: 960px;
        padding: 2.5rem 2.5rem 3rem;
      }
      .page-header {
        margin-bottom: 1.75rem;
      }
      .page-header h1 {
        font-size: 1.7rem;
        margin: 0 0 0.3rem;
        color: #004d7a;
      }
      .page-header p {
        font-size: 0.9rem;
        color: #4b5563;
        max-width: 760px;
      }
      .admin-card {
        background: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.15);
        border: 1px solid rgba(148, 163, 184, 0.25);
        padding: 2rem 1.75rem;
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 4fr);
        gap: 1.75rem;
      }
      @media (max-width: 768px) {
        .admin-card {
          grid-template-columns: minmax(0, 1fr);
          padding: 1.5rem 1.4rem;
        }
      }
      .admin-intro .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        background: #eff6ff;
        font-size: 0.7rem;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        margin-bottom: 0.75rem;
      }
      .admin-intro .pill-dot {
        width: 0.4rem;
        height: 0.4rem;
        border-radius: 999px;
        background: #22c55e;
      }
      .admin-intro p {
        font-size: 0.9rem;
        color: #4b5563;
        line-height: 1.5;
      }
      .admin-intro .permission-note {
        font-size: 0.78rem;
        color: #6b7280;
        margin-top: 0.9rem;
      }
      .login-panel .panel-header {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #1f2937;
      }
      .login-panel .panel-subtitle {
        font-size: 0.78rem;
        color: #6b7280;
        margin-bottom: 0.9rem;
      }
      .login-panel label {
        display: block;
        font-size: 0.8rem;
        color: #374151;
        margin-bottom: 0.25rem;
      }
      .login-panel input {
        width: 100%;
        padding: 0.5rem 0.6rem;
        border-radius: 0.5rem;
        border: 1px solid #d1d5db;
        font-size: 0.85rem;
        margin-bottom: 0.7rem;
        box-sizing: border-box;
      }
      .login-panel input:focus {
        outline: none;
        border-color: #218cc5;
        box-shadow: 0 0 0 2px rgba(33, 140, 197, 0.2);
      }
      .btn-login {
        width: 100%;
        padding: 0.6rem 0.6rem;
        font-size: 0.9rem;
        border-radius: 0.5rem;
        background: #218cc5;
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        margin-top: 0.4rem;
      }
      .btn-login:hover {
        background: #1d7696;
      }
      .btn-login:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }
      .link-inline {
        color: #1d4ed8;
        text-decoration: none;
        font-size: 0.85rem;
      }
      .link-inline:hover {
        text-decoration: underline;
      }
      .footer-switch {
        margin-top: 1.5rem;
        font-size: 0.75rem;
        color: #6b7280;
        text-align: right;
      }
      .footer-switch a {
        color: #1d4ed8;
        text-decoration: none;
        margin-left: 0.4rem;
      }
      .footer-switch a.active {
        font-weight: 600;
        text-decoration: underline;
      }
      .toast-container {
        position: fixed;
        right: 1rem;
        top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        z-index: 50;
      }
      .toast {
        min-width: 220px;
        max-width: 340px;
        padding: 0.6rem 0.8rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.5);
        background: #ffffff;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.25);
        font-size: 0.8rem;
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        animation: fade-in 0.15s ease-out;
      }
      .toast-success {
        border-color: rgba(34, 197, 94, 0.6);
      }
      .toast-error {
        border-color: rgba(248, 113, 113, 0.85);
      }
      .toast-icon { margin-top: 0.05rem; font-size: 0.85rem; }
      .toast-close {
        margin-left: auto;
        cursor: pointer;
        border: none;
        background: none;
        font-size: 0.85rem;
        color: #6b7280;
      }
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(-4px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
  body
    .page-shell
      .page-header
        h1 #{isSw ? 'WAJA/UCS - Usimamizi wa Email za Uanzishaji' : 'WAJA/UCS - CHW Activation Email Management'}
        p #{isSw ? 'Ingia kwenye ukurasa maalum wa wasimamizi wa email za uanzishaji za CHW.' : 'Sign in to access the activation email control dashboard.'}

      .admin-card
        .admin-intro
          span.pill
            span.pill-dot
            span #{isSw ? 'Zana za Wasimamizi' : 'Admin Tools'}
          h2(style="font-size:1.1rem; font-weight:600; margin:0 0 0.5rem; color:#1f2937;")
            | #{isSw ? 'Kuhusu ukurasa huu' : 'About this page'}
          p
            | #{isSw ? 'Huu ni ukurasa maalum wa wasimamizi kufuatilia na kudhibiti email za uanzishaji za Wasaidizi wa Afya ya Jamii (CHW). Baada ya kuingia utaweza kuona takwimu, kutuma upya makundi ya email na kusanidi ratiba za kutuma.' : 'This is a dedicated page for administrators to monitor and control activation emails for Community Health Workers (CHW). After signing in you can view statistics, resend email batches, and configure sending schedules.'}
          p.permission-note
            | #{isSw ? 'Hakikisha unatumia akaunti yenye ruhusa za ' : 'Ensure you use an account with '}
            strong MOH_ADMIN
            | #{isSw ? ' au ' : ' or '}
            strong UCS_DEVELOPER
            | .

        .login-panel
          h2.panel-header #{isSw ? 'Ingia kama Msimamizi' : 'Log in as Administrator'}
          p.panel-subtitle
            | #{isSw ? 'Tumia akaunti ileile unayotumia kwenye mfumo wa WAJA/UCS. Baada ya kuingia utapelekwa kwenye ukurasa wa usimamizi wa email za uanzishaji.' : 'Use the same account you use in the WAJA/UCS system. After signing in you will be redirected to the activation email management page.'}

          form#loginForm(onSubmit="return false;")
            label(for="email") #{isSw ? 'Barua Pepe (Admin)' : 'Email (Admin)'}
            input#email(type="email" name="email" required placeholder=(isSw ? 'admin@mfano.org' : 'admin@example.org'))

            label(for="password") #{isSw ? 'Nenosiri' : 'Password'}
            input#password(type="password" name="password" required placeholder="********")

            button#btnLogin.btn-login(type="submit")
              span#btnLoginSpinner(style="display:none; width:0.9rem; height:0.9rem; border-radius:999px; border:2px solid rgba(255,255,255,0.6); border-top-color:transparent; animation:spin 0.8s linear infinite;")
              span #{isSw ? 'Ingia' : 'Sign in'}

            p#loginStatus(style="font-size:0.78rem; margin-top:0.6rem; color:#6b7280; min-height:1.1rem;")

          hr(style="margin:1.25rem 0; border:none; border-top:1px solid #e5e7eb;")

          p.panel-subtitle(style="margin-bottom:0.4rem;")
            | #{isSw ? 'Baada ya kuingia, unaweza kufungua moja kwa moja ukurasa wa kudhibiti email za uanzishaji:' : 'After signing in, you can open the activation email control page directly:'}
          a.link-inline(href=`${ssrUrlPrefix}/api/v1/user/admin/activation-email-control${lang === 'sw' ? '?lang=sw' : ''}`)
            | #{isSw ? 'Fungua ukurasa wa Usimamizi wa Email za Uanzishaji' : 'Open Email Activation Management page'}

      .footer-switch
        - const loginBaseHref = `${ssrUrlPrefix}/api/v1/user/admin/login`;
        span Language:
        a(href=`${loginBaseHref}?lang=en`, class=(!isSw ? 'active' : '')) English
        span |
        a(href=`${loginBaseHref}?lang=sw`, class=(isSw ? 'active' : '')) Kiswahili

    .toast-container#toastContainer

    script.
      (function () {
        const prefix = "#{ssrUrlPrefix}".replace(/\/+$/, "");
        const isSw = "#{lang}" === "sw";
        function $(id) { return document.getElementById(id); }

        function pushToast(message, type) {
          const container = $("toastContainer");
          if (!container) return;
          const toast = document.createElement("div");
          toast.className = "toast " + (type === "success" ? "toast-success" : "toast-error");
          toast.innerHTML =
            '<span class="toast-icon">' + (type === "success" ? "✅" : "⚠️") + "</span><div>" + message + '</div><button class="toast-close" aria-label="' + (isSw ? "Funga" : "Close") + '">&times;</button>';
          const closeBtn = toast.querySelector(".toast-close");
          if (closeBtn) closeBtn.addEventListener("click", function () { container.removeChild(toast); });
          container.appendChild(toast);
          setTimeout(function () { if (container.contains(toast)) container.removeChild(toast); }, 6000);
        }

        async function doLogin() {
          const email = $("email")?.value || "";
          const password = $("password")?.value || "";
          const statusEl = $("loginStatus");
          const msgPleaseFill = isSw ? "Tafadhali jaza barua pepe na nenosiri." : "Please enter email and password.";
          if (!email || !password) {
            if (statusEl) statusEl.textContent = msgPleaseFill;
            pushToast(msgPleaseFill, "error");
            return;
          }
          if (statusEl) statusEl.textContent = isSw ? "Inakutambua, tafadhali subiri..." : "Signing you in, please wait...";
          const btn = $("btnLogin");
          const spinner = $("btnLoginSpinner");
          if (btn) btn.disabled = true;
          if (spinner) spinner.style.display = "inline-block";

          try {
            const res = await fetch(prefix + "/api/v1/auth/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email, password }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok || data?.status !== "success") {
              throw new Error(data?.message || (isSw ? "Imeshindikana kuingia. Hakikisha taarifa zako ziko sahihi." : "Sign-in failed. Please check your credentials."));
            }
            const okMsg = isSw ? "Umefanikiwa kuingia. Unapelekwa kwenye ukurasa wa usimamizi..." : "Signed in successfully. Redirecting to the management page...";
            if (statusEl) statusEl.textContent = okMsg;
            pushToast(okMsg, "success");
            const langParam = isSw ? "?lang=sw" : "";
            window.location.href = prefix + "/api/v1/user/admin/activation-email-control" + langParam;
          } catch (e) {
            console.error("Login failed:", e);
            const errMsg = e.message || (isSw ? "Imeshindikana kuingia." : "Sign-in failed.");
            if (statusEl) statusEl.textContent = errMsg;
            pushToast(errMsg, "error");
          } finally {
            if (btn) btn.disabled = false;
            if (spinner) spinner.style.display = "none";
          }
        }

        document.addEventListener("DOMContentLoaded", function () {
          const form = $("loginForm");
          if (form) form.addEventListener("submit", function (ev) { ev.preventDefault(); doLogin(); });
        });
      })();
